#%% SPC US HAIL WITH REPORTS
import geopandas as gpd
import pandas as pd
import matplotlib.pyplot as plt
import cartopy.crs as ccrs
import cartopy.feature as cf
from cartopy.feature import NaturalEarthFeature
from shapely.geometry import box
import matplotlib.patches as mpatches

# ---------------------------------------------------------
# TORNADO RISK ORDER (SPC)
# ---------------------------------------------------------
risk_order = ["5", "15", "30", "45", "60", "SIGN"]

# ---------------------------------------------------------
# SPC Base Map Setup
# ---------------------------------------------------------
proj = ccrs.LambertConformal(
    central_longitude=-96.,
    central_latitude=39.,
    standard_parallels=(33., 45.)
)

fig = plt.figure(figsize=(19.2, 10.8))
ax = plt.axes(projection=proj)
ax.set_extent([-125., -70., 22., 50.])

STATES = NaturalEarthFeature(
    category='cultural',
    name='admin_1_states_provinces_lines',
    scale='50m',
    facecolor='none'
)

ax.add_feature(cf.LAND, color='white')
ax.add_feature(cf.OCEAN, color='lightblue')
ax.add_feature(cf.COASTLINE, edgecolor='black', linewidth=1.0, zorder=4)
ax.add_feature(STATES, edgecolor='black', linewidth=1.0, zorder=4)
ax.add_feature(cf.BORDERS, edgecolor='black', linewidth=1.0, zorder=4)
ax.add_feature(cf.LAKES, color='lightblue', linewidth=1.0, edgecolor='black', zorder=4)

# ---------------------------------------------------------
legend_handles = [
    mpatches.Patch(facecolor='#8d543e', edgecolor="black", label="5%"),
    mpatches.Patch(facecolor='#fd9f3f', edgecolor="black", label="15%"),
    mpatches.Patch(facecolor='#ff1d1d', edgecolor="black", label="30%"),
    mpatches.Patch(facecolor='#fd3afd', edgecolor="black", label="45%"),
    mpatches.Patch(facecolor='#9d44f0', edgecolor="black", label="60%"),
    mpatches.Patch(facecolor='white', edgecolor="black", hatch="///", label="SIGN")
]

report_handles = [
    mpatches.Patch(facecolor='green',  edgecolor="black", label="Hail (1+ in.)"),
    mpatches.Patch(facecolor='green',  edgecolor="lime", label="Sig. Hail (2+ in.)")
]

spc_legend = ax.legend(
    handles=legend_handles,
    title="SPC Hail Probabilities",
    loc="lower left",
    frameon=True,
    fontsize=12,
    title_fontsize=18,
)

report_legend = ax.legend(
    handles=report_handles,
    title="Storm Reports",
    loc="lower right",
    frameon=True,
    fontsize=12,
    title_fontsize=18,
)

ax.add_artist(report_legend)
ax.add_artist(spc_legend)

# ---------------------------------------------------------
# TORNADO COLORS (SPC official)
# ---------------------------------------------------------
TOR_COLORS = {
    "5":  "#8d543e",
    "15": "#fd9f3f",
    "30": "#ff1d1d",
    "45": "#fd3afd",
    "60": "#9d44f0",
    "SIGN": "#ffffff"   # hatched
}

# ---------------------------------------------------------
# LOAD SPC TORNADO OUTLOOK FROM LOCAL GEOJSON
# ---------------------------------------------------------
SPC_FILE = "day1otlk_20250425_1630_hail.lyr.geojson"

spc_raw = gpd.read_file(SPC_FILE)

# ---------------------------------------------------------
# Clip box in EPSG:4326
# ---------------------------------------------------------
map_extent = gpd.GeoDataFrame(
    geometry=[box(-125, 20, -70, 60)],
    crs="EPSG:4326"
)

spc_raw = gpd.clip(spc_raw, map_extent)

# Handle MultiPolygons
spc_raw = spc_raw.explode(index_parts=False)

# ---------------------------------------------------------
# DRAW TORNADO POLYGONS USING DN FIELD (CORRECT)
# ---------------------------------------------------------
for risk in risk_order:

    # DN contains integer probabilities (2, 5, 10, 15, 30, 45)
    if risk != "SIGN":
        subset = spc_raw[spc_raw["DN"].astype(str) == risk]
    else:
        subset = spc_raw[spc_raw["LABEL2"].str.contains("Significant", case=False, na=False)] \
                 if "LABEL2" in spc_raw.columns else gpd.GeoDataFrame()

    if subset.empty:
        continue

    # SIG tornado area (hatched)
    if risk == "SIGN":
        subset.plot(
            ax=ax,
            facecolor="none",
            edgecolor="black",
            linewidth=1.2,
            hatch="///",
            alpha=1,
            zorder=4,
            transform=ccrs.PlateCarree()
        )

    # Standard tornado probabilities
    else:
        subset.plot(
            ax=ax,
            facecolor=TOR_COLORS[risk],
            edgecolor="none",
            linewidth=1.2,
            alpha=1,
            zorder=3.9,
            transform=ccrs.PlateCarree()
        )

# ---------------------------------------------------------
# ADD HAIL REPORTS (SIZE-BASED SYMBOLS)
# ---------------------------------------------------------
hail_reports = pd.read_csv("250425_rpts_hail.csv")
hail_reports.columns = hail_reports.columns.str.lower()

if "lat" in hail_reports.columns and "lon" in hail_reports.columns and "size" in hail_reports.columns:

    # Normal hail (< 200)
    normal = hail_reports[hail_reports["size"] < 200]

    ax.scatter(
        normal["lon"],
        normal["lat"],
        color="green",
        marker="o",
        s=60,
        edgecolor="black",
        linewidth=0.7,
        transform=ccrs.PlateCarree(),
        zorder=10
    )

    # Giant hail (>= 200)
    giant = hail_reports[hail_reports["size"] >= 200]

    ax.scatter(
        giant["lon"],
        giant["lat"],
        color="green",
        marker="D",   # diamond for giant hail
        s=80,
        edgecolor="lime",
        linewidth=0.9,
        transform=ccrs.PlateCarree(),
        zorder=11
    )

else:
    print("CSV missing required columns:", hail_reports.columns)



# ---------------------------------------------------------
# Title + Gridlines
# ---------------------------------------------------------
ax.gridlines(draw_labels=True, color='gray', alpha=0.4, linestyle='--')
ax.set_title("SPC Hail Outlook – 1630Z April 25th, 2025", fontsize=18)

plt.savefig("SPCHailOutlookREPORTS.png")
plt.show()
