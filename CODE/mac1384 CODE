#%% Reflectivity Zoomed
import cartopy.crs as ccrs
import matplotlib.gridspec as gridspec
import matplotlib.pyplot as plt
import numpy as np

from metpy.calc import azimuth_range_to_lat_lon
from metpy.io import Level2File
from metpy.units import units
from metpy.plots import USCOUNTIES
from cartopy.feature import NaturalEarthFeature

STATES = NaturalEarthFeature(
    category='cultural',
    name='admin_1_states_provinces_lines',
    scale='50m',
    facecolor='none'
)

#Open file
fname = 'KLBB20250425_210052_V06'
f = Level2File(fname)

sweep = 0

az = np.array([ray[0].az_angle for ray in f.sweeps[sweep]])

diff = np.diff(az)
crossed = diff < -180
diff[crossed] += 360.
avg_spacing = diff.mean()

az = (az[:-1] + az[1:]) / 2
az[crossed] += 180.
az = np.concatenate(([az[0] - avg_spacing], az, [az[-1] + avg_spacing]))
az = units.Quantity(az, 'degrees')

###########################################
# Gate ranges + data

ref_hdr = f.sweeps[sweep][0][4][b'REF'][0]
ref_range = (np.arange(ref_hdr.num_gates + 1) - 0.5) * ref_hdr.gate_width + ref_hdr.first_gate
ref_range = units.Quantity(ref_range, 'kilometers')
ref = np.array([ray[4][b'REF'][1] for ray in f.sweeps[sweep]])

###########################################
# Radar's TRUE location from file

radar_lon = f.sweeps[0][0][1].lon
radar_lat = f.sweeps[0][0][1].lat

#Map Center
map_lon = -102.6
map_lat = 33.95

###########################################
# Convert radar polar → geographic coordinates

xlocs, ylocs = azimuth_range_to_lat_lon(az, ref_range, radar_lon, radar_lat)

###########################################
# Plot

fig = plt.figure(figsize=(19.2,10.8))
ax = fig.add_subplot(1, 1, 1, projection=ccrs.PlateCarree())

